# ================================
# ChatForge Configuration
# ================================

# ----------------------------------------------------------------
# Business Information
# ----------------------------------------------------------------

BUSINESS_NAME="Ashmin Dhungana"
BUSINESS_DESCRIPTION="Hi, I'm AI Engineer, I  Build Intelligent Applications "
BUSINESS_HOURS="Sun-Fri 10AM-5PM, Sat 11AM-4PM"
BUSINESS_PHONE="+977 98624296222"
BUSINESS_ADDRESS="Main Road, Biratnagar, Nepal"
BUSINESS_WEBSITE="https://github.com/AshminDhungana"

# ----------------------------------------------------------------
# Security / Widget Authentication
# ----------------------------------------------------------------

# Unique identifier for this chatbot instance
PROJECT_ID="ashmin-office"

# Allowed domains (comma separated)
ALLOWED_DOMAINS="ashmindhungana.com,www.dhungana_ashmin.com,localhost,127.0.0.1"

# Optional widget secret
# Recommended for production deployments
WIDGET_API_KEY="change-me-to-a-random-secret"

# ----------------------------------------------------------------
# Quick Reply Buttons
# ----------------------------------------------------------------

QUICK_REPLIES="What are your hours?,Where are you located?,How can I contact you?"

# ----------------------------------------------------------------
# AI Configuration
# ----------------------------------------------------------------

# Leave API_KEY blank to use the rule-based fallback engine instead
API_KEY=""
MODEL="llama-3.1-8b-instant"

# ----------------------------------------------------------------
# API Base URL
# Uncomment ONE provider. Groq is recommended — free and no credit card required.
# ----------------------------------------------------------------

# Groq (recommended — free tier, no credit card required)
API_BASE="https://api.groq.com/openai/v1"

# OpenAI
# API_BASE="https://api.openai.com/v1"

# Together AI
# API_BASE="https://api.together.xyz/v1"

# OpenRouter
# API_BASE="https://openrouter.ai/api/v1"

# Ollama (local — requires a running Ollama instance)
# API_BASE="http://localhost:11434/v1"

# Other OpenAI Compatible APIs
# API_BASE="https://your-api-url.com/v1"

# ----------------------------------------------------------------
# Widget Configuration
# ----------------------------------------------------------------

WIDGET_COLOR="#2563EB"
GREETING_MESSAGE="Hi! Welcome to Ashmin's Office 🍕 How can I help you today?"

# ----------------------------------------------------------------
# Rate Limiting
# Format: "<number>/minute" — e.g. "20/minute" allows 20 requests per session per minute
# ----------------------------------------------------------------

RATE_LIMIT="20/minute"
